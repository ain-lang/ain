# ═══════════════════════════════════════════════════════════════════════════
# 🛡️ AIN PROTECTED FILES - 최소 보호 (진화 자유 보장)
# ═══════════════════════════════════════════════════════════════════════════
# 
# ⚠️ 주의: 여기 나열된 파일만 보호됩니다. 최소한으로 유지하세요!
# AIN의 진화 능력을 제한하지 않으면서, 핵심 인프라만 보호합니다.
#
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 🫀 CORE INFRASTRUCTURE - 핵심 보호 (5개)
# ─────────────────────────────────────────────────────────────────────────────
main.py                     # 시스템 부팅 루프 - 망가지면 시작 불가
api/keys.py                 # API 키 - 보안
api/github.py               # 커밋/푸시 - 망가지면 진화 저장 불가
code_sanitizer.py           # Coder 출력 후처리 - 오류 패턴 제거/감지
.ainprotect                 # 이 파일 - 보호 시스템 자체

# ─────────────────────────────────────────────────────────────────────────────
# 📚 REFERENCE DOCUMENTS - 참고 문서 (읽기 전용)
# ─────────────────────────────────────────────────────────────────────────────
docs/hardware-catalog.md    # 하드웨어 카탈로그 - 주인님 요청용 참고 자료

# ─────────────────────────────────────────────────────────────────────────────
# ✅ 진화 가능 (보호 안 함)
# ─────────────────────────────────────────────────────────────────────────────
# overseer.py              → AIN이 검증 로직 개선 가능
# database/surreal_bridge.py → AIN이 DB 기능 확장 가능
# ROADMAP.md               → AIN이 진행 상태 업데이트 가능
# corpus_callosum.py       → AIN이 자유롭게 진화
# fact_core.py             → AIN이 자유롭게 진화
# nexus.py                 → AIN이 자유롭게 진화
# muse.py                  → AIN이 자유롭게 진화

# ═══════════════════════════════════════════════════════════════════════════
# 🚨 CRITICAL INTERFACE CONTRACTS - 삭제/변경 절대 금지!
# ═══════════════════════════════════════════════════════════════════════════
# 
# 아래 메서드/로직은 ain_engine.py 또는 다른 핵심 모듈에서 호출됩니다.
# 진화 시 이 인터페이스를 반드시 유지하세요!
#
# ─────────────────────────────────────────────────────────────────────────────
# corpus_callosum.py 필수 인터페이스:
# ─────────────────────────────────────────────────────────────────────────────
#   def get_bridge_status(self) -> Dict[str, Any]
#   def sync_facts_to_surreal(self) -> bool
#   def synthesize_context(self, user_query: str = None) -> str
#   async def hydrate_from_db(self) -> bool
#   async def sync_pulse(self) -> bool
#
# ─────────────────────────────────────────────────────────────────────────────
# nexus.py 필수 인터페이스:
# ─────────────────────────────────────────────────────────────────────────────
#   def load_data(self, filepath: str) -> List[Dict]
#   def save_data(self, filepath: str, data: List[Dict])
#   def record_evolution(self, ...)
#   def get_evolution_summary(self) -> str
#   memory_file: str (인스턴스 변수)
#   metrics_file: str (인스턴스 변수)
#
# ─────────────────────────────────────────────────────────────────────────────
# fact_core.py 필수 인터페이스:
# ─────────────────────────────────────────────────────────────────────────────
#   def get_fact(self, category: str, key: str = None) -> Any
#   def get_core_context(self) -> str
#   nodes: Dict[str, Node] (인스턴스 변수)
#   facts: Dict (인스턴스 변수)
#
# ─────────────────────────────────────────────────────────────────────────────
# muse.py 필수 로직 (삭제 금지!):
# ─────────────────────────────────────────────────────────────────────────────
#   # Coder 응답에서 ''' → ``` 자동 치환 (Claude가 간혹 잘못 사용)
#   if "'''" in code_output:
#       code_output = code_output.replace("'''", "```")
#
# ═══════════════════════════════════════════════════════════════════════════
# ⚠️ 위 인터페이스를 삭제하면 ain_engine.py에서 AttributeError 발생!
# ⚠️ 기능 추가는 OK, 기존 메서드 삭제/이름 변경은 NEVER!
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# 📏 AIN 코딩 규칙 - 모든 진화에 적용
# ═══════════════════════════════════════════════════════════════════════════
#
# ─────────────────────────────────────────────────────────────────────────────
# 🏗️ 모듈 크기 제한 - 절대 준수!
# ─────────────────────────────────────────────────────────────────────────────
#   - 파일당 100줄 이하 권장 (최대 150줄)
#   - 단일 책임 원칙: 한 파일에 한 가지 기능만
#   - 새 기능은 별도 파일로 생성 (utils/*.py, database/*.py 등)
#   - 기존 파일에는 import 한 줄만 추가
#   - 200줄 이상 코드 출력 시 토큰 한계로 잘림 → 오류 발생!
#
# ─────────────────────────────────────────────────────────────────────────────
# 📝 주석/문서화 - 필수!
# ─────────────────────────────────────────────────────────────────────────────
#   - 파일 상단: """모듈 설명 docstring""" 필수
#   - 클래스: 역할과 책임 설명
#   - 함수/메서드: 목적, 파라미터(Args), 반환값(Returns) 설명
#   - 복잡한 로직: # 인라인 주석으로 동작 설명
#
# ─────────────────────────────────────────────────────────────────────────────
# ✅ 수정 가능한 파일 (모듈화 완료)
# ─────────────────────────────────────────────────────────────────────────────
#   - nexus/*.py (core.py, memory.py, history.py, arrow.py, storage.py)
#   - engine/*.py (core.py, sync.py, evolution.py, handlers.py, introspect.py, loop.py)
#   - corpus/*.py (core.py, hydration.py, sync.py, transform.py)
#   - facts/*.py (node.py, core.py, storage.py, graph.py, snapshot.py)
#   - database/*.py, api/*.py
#   - 새로 생성하는 파일 (utils/*.py 등)
#
# ═══════════════════════════════════════════════════════════════════════════
